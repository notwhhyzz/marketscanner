//@version=6
indicator("ILT", shorttitle="ILT", overlay=true, max_boxes_count=100, max_lines_count=50, max_labels_count=100)

// ─────────────────────────────────────────
//  IMPOSTAZIONI
// ─────────────────────────────────────────

i_lookback  = input.int(20,    "Lookback zone",        minval=5,   maxval=100)
i_volmult   = input.float(2.0, "Volume spike (× avg)", minval=1.0, maxval=6.0, step=0.1)
i_zonewidth = input.float(0.2, "Ampiezza zona (%)",    minval=0.05, maxval=1.0, step=0.05)
i_sens      = input.string("MEDIA", "Sensibilità",     options=["BASSA","MEDIA","ALTA"])
i_showzones = input.bool(true, "Mostra zone liquidità")
i_showsig   = input.bool(true, "Mostra segnali")
i_showvol   = input.bool(true, "Mostra spike volume")

// ─────────────────────────────────────────
//  TIMEFRAME
// ─────────────────────────────────────────

tf_min      = timeframe.in_seconds(timeframe.period) / 60
is_scalping = tf_min <= 5
is_intraday = tf_min > 5 and tf_min <= 60
is_swing    = tf_min > 60

// ─────────────────────────────────────────
//  CALCOLI
// ─────────────────────────────────────────

// EMA
ema9   = ta.ema(close, 9)
ema21  = ta.ema(close, 21)
ema200 = ta.ema(close, 200)

// RSI, ATR, MACD
rsi              = ta.rsi(close, 14)
atr              = ta.atr(14)
[macd, sig, _]   = ta.macd(close, 12, 26, 9)
macd_bull        = macd > sig

// Volume
vol_avg   = ta.sma(volume, 20)
vol_ratio = volume / vol_avg
vol_spike = vol_ratio >= i_volmult

// Swing levels — lookback adattivo per TF
lb = is_scalping ? i_lookback : is_intraday ? i_lookback * 2 : i_lookback * 4
swing_hi = ta.pivothigh(high, lb, lb)
swing_lo = ta.pivotlow(low,   lb, lb)

// Score segnale
sens_min = i_sens == "ALTA" ? 1 : i_sens == "MEDIA" ? 2 : 3

buy_score  = (ta.crossover(ema9, ema21)             ? 1 : 0)
           + (rsi > 30 and rsi < 50                  ? 1 : 0)
           + (macd_bull                              ? 1 : 0)
           + (close > ema200                         ? 1 : 0)

sell_score = (ta.crossunder(ema9, ema21)             ? 1 : 0)
           + (rsi > 50 and rsi < 75                  ? 1 : 0)
           + (not macd_bull                          ? 1 : 0)
           + (close < ema200                         ? 1 : 0)

buy_sig  = buy_score  >= sens_min and barstate.isconfirmed
sell_sig = sell_score >= sens_min and barstate.isconfirmed

// ─────────────────────────────────────────
//  COLORI (palette minimal)
// ─────────────────────────────────────────

c_green     = color.new(#34c759, 0)
c_red       = color.new(#ff3b30, 0)
c_blue      = color.new(#007aff, 0)
c_zone_buy  = color.new(#34c759, 82)
c_zone_sell = color.new(#ff3b30, 82)
c_whale     = color.new(#ff9f0a, 0)

// ─────────────────────────────────────────
//  EMA PLOTS
//  Scalping: 9 + 21 + 200
//  Intraday: 21 + 200
//  Swing:    solo 200
// ─────────────────────────────────────────

plot(is_scalping ? ema9   : na, "EMA 9",   color=color.new(c_blue,  20), linewidth=1)
plot(not is_swing ? ema21 : na, "EMA 21",  color=color.new(c_green, 30), linewidth=1)
plot(ema200,                    "EMA 200", color=color.new(#8e8e93, 30), linewidth=2)

// ─────────────────────────────────────────
//  ZONE DI LIQUIDITÀ
//  Minimal: solo box semitrasparente, niente label
//  Il prezzo è leggibile passandoci sopra col mouse
// ─────────────────────────────────────────

zw           = i_zonewidth / 100.0
bar_dur      = time - time[1]

if not na(swing_lo) and i_showzones
    lp = swing_lo
    box.new(
      left=time[lb], top=lp*(1.0+zw), right=time+10*bar_dur, bottom=lp*(1.0-zw),
      xloc=xloc.bar_time,
      bgcolor=c_zone_buy,
      border_color=color.new(c_green, 50),
      border_width=1)

if not na(swing_hi) and i_showzones
    hp = swing_hi
    box.new(
      left=time[lb], top=hp*(1.0+zw), right=time+10*bar_dur, bottom=hp*(1.0-zw),
      xloc=xloc.bar_time,
      bgcolor=c_zone_sell,
      border_color=color.new(c_red, 50),
      border_width=1)

// ─────────────────────────────────────────
//  SEGNALI BUY / SELL
//  Minimal: solo triangolo + prezzo nel tooltip
// ─────────────────────────────────────────

sl_b  = close - atr * 1.5
tp1_b = close + atr * 2.0
tp2_b = close + atr * 3.5
sl_s  = close + atr * 1.5
tp1_s = close - atr * 2.0
tp2_s = close - atr * 3.5

tip_b = "BUY  " + str.tostring(math.round(close,2)) + "  ·  SL " + str.tostring(math.round(sl_b,2)) + "  ·  TP1 " + str.tostring(math.round(tp1_b,2)) + "  ·  TP2 " + str.tostring(math.round(tp2_b,2)) + "  ·  RSI " + str.tostring(math.round(rsi,1)) + "  ·  Vol " + str.tostring(math.round(vol_ratio,1)) + "×  ·  " + str.tostring(buy_score) + "/4"
tip_s = "SELL  " + str.tostring(math.round(close,2)) + "  ·  SL " + str.tostring(math.round(sl_s,2)) + "  ·  TP1 " + str.tostring(math.round(tp1_s,2)) + "  ·  TP2 " + str.tostring(math.round(tp2_s,2)) + "  ·  RSI " + str.tostring(math.round(rsi,1)) + "  ·  Vol " + str.tostring(math.round(vol_ratio,1)) + "×  ·  " + str.tostring(sell_score) + "/4"

if buy_sig and i_showsig
    label.new(
      x=time, y=low - atr*0.8,
      text="▲", tooltip=tip_b,
      xloc=xloc.bar_time,
      style=label.style_label_up,
      color=color.new(c_green, 10),
      textcolor=color.white,
      size=is_scalping ? size.normal : size.small)

if sell_sig and i_showsig
    label.new(
      x=time, y=high + atr*0.8,
      text="▼", tooltip=tip_s,
      xloc=xloc.bar_time,
      style=label.style_label_down,
      color=color.new(c_red, 10),
      textcolor=color.white,
      size=is_scalping ? size.normal : size.small)

// ─────────────────────────────────────────
//  LINEE SL / TP (solo scalping e intraday)
// ─────────────────────────────────────────

var line l_sl  = na
var line l_tp1 = na
var line l_tp2 = na

if not is_swing
    if buy_sig
        if not na(l_sl)
            line.delete(l_sl)
        if not na(l_tp1)
            line.delete(l_tp1)
        if not na(l_tp2)
            line.delete(l_tp2)
        l_sl  := line.new(x1=time, y1=sl_b,  x2=time+15*bar_dur, y2=sl_b,  xloc=xloc.bar_time, color=color.new(c_red,   50), width=1, style=line.style_dashed)
        l_tp1 := line.new(x1=time, y1=tp1_b, x2=time+15*bar_dur, y2=tp1_b, xloc=xloc.bar_time, color=color.new(c_green, 50), width=1, style=line.style_dashed)
        if is_scalping
            l_tp2 := line.new(x1=time, y1=tp2_b, x2=time+15*bar_dur, y2=tp2_b, xloc=xloc.bar_time, color=color.new(c_green, 70), width=1, style=line.style_dotted)
    if sell_sig
        if not na(l_sl)
            line.delete(l_sl)
        if not na(l_tp1)
            line.delete(l_tp1)
        if not na(l_tp2)
            line.delete(l_tp2)
        l_sl  := line.new(x1=time, y1=sl_s,  x2=time+15*bar_dur, y2=sl_s,  xloc=xloc.bar_time, color=color.new(c_green, 50), width=1, style=line.style_dashed)
        l_tp1 := line.new(x1=time, y1=tp1_s, x2=time+15*bar_dur, y2=tp1_s, xloc=xloc.bar_time, color=color.new(c_red,   50), width=1, style=line.style_dashed)
        if is_scalping
            l_tp2 := line.new(x1=time, y1=tp2_s, x2=time+15*bar_dur, y2=tp2_s, xloc=xloc.bar_time, color=color.new(c_red, 70), width=1, style=line.style_dotted)

// ─────────────────────────────────────────
//  VOLUME SPIKE — solo barre colorate, niente label
//  Scalping: ≥ 2×   Intraday: ≥ 2.5×   Swing: ≥ 3×
// ─────────────────────────────────────────

vol_thr = is_scalping ? i_volmult : is_intraday ? i_volmult * 1.25 : i_volmult * 1.5

barcolor(vol_ratio >= vol_thr * 1.5 ? color.new(c_whale, 20) :
         vol_ratio >= vol_thr       ? color.new(c_whale, 50) : na)

if vol_spike and i_showvol and vol_ratio >= vol_thr
    label.new(
      x=time, y=low - atr*0.3,
      text=vol_ratio >= vol_thr*1.5 ? "●" : "·",
      tooltip="Vol " + str.tostring(math.round(vol_ratio,1)) + "× · " + str.tostring(math.round(close,2)),
      xloc=xloc.bar_time,
      style=label.style_label_up,
      color=color.new(c_whale, vol_ratio >= vol_thr*1.5 ? 10 : 40),
      textcolor=color.new(#1c1c1e, 0),
      size=size.tiny)

// ─────────────────────────────────────────
//  TABELLA — minimal, top-right, solo dati utili
// ─────────────────────────────────────────

var table tbl = table.new(
  position.top_right, 2, 6,
  bgcolor      = color.new(#1c1c1e, 10),
  border_color = color.new(#3a3a3c, 60),
  border_width = 1,
  frame_color  = color.new(#3a3a3c, 60),
  frame_width  = 1)

if barstate.islast
    tf_str = is_scalping ? "SCALP" : is_intraday ? "INTRA" : "SWING"
    tf_col = is_scalping ? color.new(#ff9f0a,0) : is_intraday ? color.new(#007aff,0) : color.new(#34c759,0)

    table.cell(tbl, 0, 0, "ILT",    text_color=color.new(#ffffff,0), text_size=size.small, bgcolor=color.new(#2c2c2e,20))
    table.cell(tbl, 1, 0, tf_str,   text_color=tf_col,               text_size=size.small, bgcolor=color.new(#2c2c2e,20))

    table.cell(tbl, 0, 1, "Price",  text_color=color.new(#8e8e93,0), text_size=size.tiny)
    table.cell(tbl, 1, 1, str.tostring(math.round(close,2)),
               text_color=close >= open ? c_green : c_red, text_size=size.tiny)

    table.cell(tbl, 0, 2, "RSI",    text_color=color.new(#8e8e93,0), text_size=size.tiny)
    table.cell(tbl, 1, 2, str.tostring(math.round(rsi,1)),
               text_color=rsi>70?c_red:rsi<30?c_green:color.new(#8e8e93,0), text_size=size.tiny)

    table.cell(tbl, 0, 3, "Vol",    text_color=color.new(#8e8e93,0), text_size=size.tiny)
    table.cell(tbl, 1, 3, str.tostring(math.round(vol_ratio,1)) + "×",
               text_color=vol_ratio>=i_volmult?c_whale:color.new(#8e8e93,0), text_size=size.tiny)

    table.cell(tbl, 0, 4, "Trend",  text_color=color.new(#8e8e93,0), text_size=size.tiny)
    table.cell(tbl, 1, 4, ema9>ema21 ? "▲" : "▼",
               text_color=ema9>ema21?c_green:c_red, text_size=size.tiny)

    table.cell(tbl, 0, 5, "Signal", text_color=color.new(#8e8e93,0), text_size=size.tiny)
    table.cell(tbl, 1, 5, buy_sig?"BUY":sell_sig?"SELL":"—",
               text_color=buy_sig?c_green:sell_sig?c_red:color.new(#8e8e93,0), text_size=size.tiny)

// ─────────────────────────────────────────
//  ALERT
// ─────────────────────────────────────────

alertcondition(buy_sig,  title="ILT BUY",   message="▲ BUY {{ticker}} @ {{close}}")
alertcondition(sell_sig, title="ILT SELL",  message="▼ SELL {{ticker}} @ {{close}}")
alertcondition(vol_ratio >= i_volmult * 1.5, title="ILT WHALE", message="● WHALE {{ticker}} @ {{close}}")
